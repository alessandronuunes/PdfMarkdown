# ===========================================
# 🔑 API KEYS PARA CONVERSÃO AI
# ===========================================

# OpenAI - Obtenha em: https://platform.openai.com/api-keys
# Custo aprox: $0.01-0.05 por PDF
OPENAI_API_KEY=sua_chave_openai_aqui

# Claude (Anthropic) - Obtenha em: https://console.anthropic.com/account/keys  
# Custo aprox: $0.005-0.03 por PDF
ANTHROPIC_API_KEY=sua_chave_claude_aqui

# ===========================================
# ⚙️ CONFIGURAÇÕES GERAIS
# ===========================================

# Método padrão de conversão: basic, openai, claude
# Recomendado: claude (melhor qualidade) ou openai (boa qualidade)
AI_METHOD=openai

# ===========================================
# 🤖 CONFIGURAÇÕES OPENAI
# ===========================================

# Modelos disponíveis: gpt-3.5-turbo, gpt-4, gpt-4o-mini
# gpt-4o-mini: melhor custo-benefício
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=8000
OPENAI_TEMPERATURE=0.1

# ===========================================
# 🔮 CONFIGURAÇÕES CLAUDE  
# ===========================================

# Modelo Claude (automático: claude-sonnet-4-6)
# Max tokens para Claude API
CLAUDE_MAX_TOKENS=4000