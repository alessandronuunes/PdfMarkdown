# PDF to Markdown Converter - Configuração de APIs
# Copie este arquivo para .env e configure suas chaves

# Método padrão (opções: basic, openai, claude, ollama)
AI_METHOD=openai

# OpenAI API (https://platform.openai.com/api-keys)
# Ganhe $5 grátis ao criar conta
OPENAI_API_KEY=sua_chave_openai_aqui
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.1

# Claude API (https://console.anthropic.com/account/keys) 
# Ganhe $5 grátis ao criar conta
ANTHROPIC_API_KEY=sua_chave_claude_aqui

# Ollama Local (opcional - apenas se usar método 'ollama')
OLLAMA_MODEL=llama3.1:8b
OLLAMA_URL=http://localhost:11434

# ===================================================
# INSTRUÇÕES:
# ===================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Edite o arquivo .env com suas chaves reais
# 3. Escolha um método no AI_METHOD
# 4. Configure apenas a chave do método escolhido
# 
# IMPORTANTE: O arquivo .env não é enviado para o Git
# por questões de segurança (suas chaves ficam privadas)